{
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./"
  },
  "include": ["./**/*.tsx", "./**/*.ts", "./**/*.jsx", "./**/*.js"]
}
